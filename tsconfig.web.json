{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/overlay/src/**/*",
    "src/overlay/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@overlay/*": ["src/overlay/src/*"]
    }
  }
}
